<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Desperse" parent="Theme.AppCompat.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/highlight</item>
        <item name="colorPrimaryDark">@color/highlight_dark</item>
        <item name="colorAccent">@color/highlight</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/statusBarColor</item>
        <item name="android:navigationBarColor">@color/statusBarColor</item>

        <!-- Android 12+ Splash Screen - always dark for consistent launch experience -->
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
    </style>
</resources>
